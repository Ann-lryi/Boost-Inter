<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:clipChildren="false">

    <!-- Ambient Lighting Blob (OriginOS style underlying glow) -->
    <View
        android:id="@+id/ambientGlow"
        android:layout_width="600dp"
        android:layout_height="600dp"
        android:background="@drawable/bg_ambient_glow"
        android:translationY="-100dp"
        android:alpha="0f"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvAppBrand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="L E V I A T H A N"
        android:textSize="12sp"
        android:letterSpacing="0.4"
        android:textStyle="bold"
        android:textColor="@color/neon_cyan"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="40dp"
        android:layout_marginStart="32dp"/>

    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quantum Core"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="@color/text_title"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toBottomOf="@id/tvAppBrand"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="4dp"
        android:layout_marginStart="32dp"/>

    <!-- Generative Art Canvas (Replaces static PNG) -->
    <com.networkoptimizer.ui.QuantumFluidView
        android:id="@+id/fluidCore"
        android:layout_width="280dp"
        android:layout_height="280dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppTitle"
        app:layout_constraintBottom_toTopOf="@id/widgetGrid"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Glassmorphism Widget Grid -->
    <LinearLayout
        android:id="@+id/widgetGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        app:layout_constraintBottom_toTopOf="@id/cardAction"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="16dp">

            <!-- Data Widget -->
            <LinearLayout
                android:id="@+id/widgetData"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:padding="24dp"
                android:layout_marginEnd="8dp"
                android:elevation="10dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATA"
                    android:textColor="@color/text_subtitle"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvBytes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 B"
                    android:textColor="@color/text_title"
                    android:textStyle="bold"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>

            <!-- Threats Widget -->
            <LinearLayout
                android:id="@+id/widgetThreats"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:padding="24dp"
                android:layout_marginStart="8dp"
                android:elevation="10dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="THREATS"
                    android:textColor="@color/text_subtitle"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvBlocked"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_title"
                    android:textStyle="bold"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Packets Widget (Full width) -->
        <LinearLayout
            android:id="@+id/widgetPackets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_glass_card"
            android:padding="24dp"
            android:gravity="center_vertical"
            android:elevation="10dp">
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PACKETS PROCESSED"
                    android:textColor="@color/text_subtitle"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvPackets"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_title"
                    android:textStyle="bold"
                    android:textSize="32sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
            
        </LinearLayout>
    </LinearLayout>

    <!-- Master Switch Card -->
    <LinearLayout
        android:id="@+id/cardAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_card"
        android:orientation="horizontal"
        android:padding="28dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="40dp"
        android:gravity="center_vertical"
        android:elevation="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvActionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVATE LEVIATHAN"
                android:textColor="@color/text_title"
                android:textStyle="bold"
                android:textSize="16sp"/>
            <TextView
                android:id="@+id/tvDnsInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="System Standby"
                android:textColor="@color/text_subtitle"
                android:textSize="12sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchVpn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:thumbTint="@color/text_title"
            app:trackTint="@color/stroke_glass"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>