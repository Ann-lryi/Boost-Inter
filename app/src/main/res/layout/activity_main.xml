<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="24dp">

    <!-- Header Section -->
    <TextView
        android:id="@+id/tvAppBrand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="L E V I A T H A N"
        android:textSize="14sp"
        android:letterSpacing="0.4"
        android:textStyle="bold"
        android:textColor="@color/neon_cyan"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Core Engine"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/text_title"
        app:layout_constraintTop_toBottomOf="@id/tvAppBrand"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="4dp"/>

    <!-- Central Quantum Core -->
    <View
        android:id="@+id/coreGlow"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_core_glow"
        android:alpha="0.0"
        app:layout_constraintTop_toBottomOf="@id/tvAppTitle"
        app:layout_constraintBottom_toTopOf="@id/widgetGrid"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/imgCore"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:src="@mipmap/ic_launcher"
        app:layout_constraintTop_toTopOf="@id/coreGlow"
        app:layout_constraintBottom_toBottomOf="@id/coreGlow"
        app:layout_constraintStart_toStartOf="@id/coreGlow"
        app:layout_constraintEnd_toEndOf="@id/coreGlow" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="STANDBY"
        android:textSize="16sp"
        android:letterSpacing="0.2"
        android:textStyle="bold"
        android:textColor="@color/text_subtitle"
        app:layout_constraintTop_toBottomOf="@id/imgCore"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <!-- Liquid Widgets Grid (OriginOS Style) -->
    <LinearLayout
        android:id="@+id/widgetGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/cardAction"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="16dp">

            <!-- Data Widget -->
            <LinearLayout
                android:id="@+id/widgetData"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_widget_off"
                android:padding="20dp"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATA"
                    android:textColor="@color/text_subtitle"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvBytes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00 B"
                    android:textColor="@color/text_title"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <!-- Threats Widget -->
            <LinearLayout
                android:id="@+id/widgetThreats"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_widget_off"
                android:padding="20dp"
                android:layout_marginStart="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="THREATS"
                    android:textColor="@color/text_subtitle"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvBlocked"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_title"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Packets Widget (Full width) -->
        <LinearLayout
            android:id="@+id/widgetPackets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_widget_off"
            android:padding="20dp"
            android:gravity="center_vertical">
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PACKETS PROCESSED"
                    android:textColor="@color/text_subtitle"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvPackets"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_title"
                    android:textStyle="bold"
                    android:textSize="28sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
            
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="@color/neon_cyan_dim"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Master Switch Card -->
    <LinearLayout
        android:id="@+id/cardAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_widget_off"
        android:orientation="horizontal"
        android:padding="24dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVATE LEVIATHAN"
                android:textColor="@color/text_title"
                android:textStyle="bold"
                android:textSize="16sp"/>
            <TextView
                android:id="@+id/tvDnsInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Priority: Idle"
                android:textColor="@color/text_subtitle"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchVpn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:thumbTint="@color/text_title"
            app:trackTint="@color/stroke_off"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>